{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["bgp_ls", "peer_state", "update"],
      "description": "Message type"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp in RFC3339 format"
    },
    "content": {
      "type": "object",
      "properties": {
        "nlri": {
          "type": "object",
          "description": "BGP-LS NLRI information",
          "properties": {
            "protocol_id": {
              "type": "string",
              "enum": ["isis_l1", "isis_l2", "ospf_v2", "direct", "static", "ospf_v3"],
              "description": "Protocol identifier"
            },
            "identifier": {
              "type": "string",
              "description": "BGP-LS identifier"
            },
            "local_node_descriptors": {
              "type": "object",
              "properties": {
                "autonomous_system": { "type": "integer" },
                "bgp_ls_id": { "type": "string" },
                "igp_router_id": { "type": "string" },
                "ospf_area_id": { "type": "string" }
              },
              "required": ["autonomous_system"]
            },
            "remote_node_descriptors": {
              "type": "object",
              "properties": {
                "autonomous_system": { "type": "integer" },
                "bgp_ls_id": { "type": "string" },
                "igp_router_id": { "type": "string" },
                "ospf_area_id": { "type": "string" }
              },
              "required": ["autonomous_system"]
            },
            "link_descriptors": {
              "type": "object",
              "properties": {
                "link_local_id": { "type": "integer" },
                "link_remote_id": { "type": "integer" },
                "ipv4_interface_address": { "type": "string", "format": "ipv4" },
                "ipv4_neighbor_address": { "type": "string", "format": "ipv4" },
                "ipv6_interface_address": { "type": "string", "format": "ipv6" },
                "ipv6_neighbor_address": { "type": "string", "format": "ipv6" }
              }
            },
            "prefix_descriptors": {
              "type": "object",
              "properties": {
                "ip_reachability_info": { "type": "string" },
                "ospf_route_type": {
                  "type": "string",
                  "enum": ["intra_area", "inter_area", "external1", "external2", "nssa1", "nssa2"]
                },
                "prefix_sid": {
                  "type": "object",
                  "properties": {
                    "flags": { "type": "string" },
                    "algorithm": { "type": "integer" },
                    "sid": { "type": "integer" }
                  }
                }
              }
            }
          }
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "type": { "const": "ls" },
                  "node": {
                    "type": "object",
                    "properties": {
                      "flags": {
                        "type": "object",
                        "properties": {
                          "overload": { "type": "boolean" },
                          "attached": { "type": "boolean" },
                          "external": { "type": "boolean" },
                          "abr": { "type": "boolean" },
                          "router": { "type": "boolean" },
                          "v6": { "type": "boolean" }
                        }
                      },
                      "name": { "type": "string" },
                      "isis_area": { "type": "array", "items": { "type": "string" } },
                      "local_router_id": { "type": "string" },
                      "local_router_idv6": { "type": "string" },
                      "sr_capabilities": {
                        "type": "object",
                        "properties": {
                          "ipv4_supported": { "type": "boolean" },
                          "ipv6_supported": { "type": "boolean" },
                          "ranges": { "type": "array" }
                        }
                      },
                      "sr_algorithms": { "type": "array" },
                      "sr_local_block": { "type": "object" }
                    }
                  },
                  "link": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "local_router_id": { "type": "string" },
                      "remote_router_id": { "type": "string" },
                      "admin_group": { "type": "integer" },
                      "default_te_metric": { "type": "integer" },
                      "igp_metric": { "type": "integer" },
                      "bandwidth": { "type": "number" },
                      "reservable_bandwidth": { "type": "number" },
                      "unreserved_bandwidth": { 
                        "type": "array",
                        "items": { "type": "number" }
                      },
                      "srlgs": {
                        "type": "array",
                        "items": { "type": "integer" }
                      },
                      "sr_adjacency_sid": { "type": "integer" }
                    }
                  },
                  "prefix": {
                    "type": "object",
                    "properties": {
                      "igp_flags": {
                        "type": "object",
                        "properties": {
                          "down": { "type": "boolean" },
                          "no_unicast": { "type": "boolean" },
                          "local_address": { "type": "boolean" },
                          "propagate_nssa": { "type": "boolean" }
                        }
                      },
                      "sr_prefix_sid": { "type": "integer" }
                    }
                  },
                  "bgp_peer_segment": {
                    "type": "object",
                    "properties": {
                      "peer_node_sid": { "type": "object" },
                      "peer_adjacency_sid": { "type": "object" },
                      "peer_set_sid": { "type": "object" }
                    }
                  }
                },
                "required": ["type"]
              },
              {
                "type": "object",
                "properties": {
                  "type": { "const": "origin" },
                  "value": { "type": "integer" }
                },
                "required": ["type", "value"]
              },
              {
                "type": "object",
                "properties": {
                  "type": { "const": "as_path" },
                  "segments": { "type": "array" }
                },
                "required": ["type", "segments"]
              },
              {
                "type": "object",
                "properties": {
                  "type": { "const": "next_hop" },
                  "value": { "type": "string" }
                },
                "required": ["type", "value"]
              }
            ]
          }
        }
      },
      "required": ["nlri", "attributes"]
    }
  },
  "required": ["type", "timestamp", "content"]
}
